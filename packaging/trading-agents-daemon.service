[Unit]
Description=Trading Agents Daemon
After=network.target

[Service]
Type=simple
User=clawdette
Group=clawdette
WorkingDirectory=/home/clawdette/trading-agents
ExecStart=/home/clawdette/trading-agents/.venv/bin/python3 /home/clawdette/trading-agents/daemon.py
Environment=PATH=/home/clawdette/trading-agents/.venv/bin:/usr/bin:/bin
Restart=always
RestartSec=5
StandardOutput=append:/home/clawdette/trading-agents/shared/state/daemon.out.log
StandardError=append:/home/clawdette/trading-agents/shared/state/daemon.err.log

[Install]
WantedBy=multi-user.target
